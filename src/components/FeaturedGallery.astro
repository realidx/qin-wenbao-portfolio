---
import WorkCard from './WorkCard.astro';
import { getFeaturedWorks } from '../data/imageStore';

const works = await getFeaturedWorks();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="container-custom">
	<div class="mb-12 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
		<div>
			<p class="mb-3 text-sm uppercase tracking-[0.22em] text-[#7b1e25]">Selected Works</p>
			<h2 class="text-3xl md:text-5xl font-semibold text-[#241f1c]">Selected Works</h2>
		</div>
		<a
			href={`${base}/works`}
			class="inline-flex w-fit border-b border-[#7b1e25] pb-1 text-sm font-medium text-[#7b1e25]"
		>
			View Full Portfolio
		</a>
	</div>

	<div class="grid gap-10 md:grid-cols-2">
		{works.map((work) => <WorkCard work={work} />)}
	</div>
</div>
