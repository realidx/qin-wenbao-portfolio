---
import siteConfig from '../../site.config.mjs';
import { Menu, X } from 'lucide-astro';

const title = siteConfig.title;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const menuItems = [
	{ name: 'Home', link: `${base}/` },
	{ name: 'Works', link: `${base}/works` },
	{ name: 'About', link: `${base}/about` },
	{ name: 'Contact', link: `${base}/contact` },
];
---

<nav
	x-data="{ isOpen: false, scrolled: false }"
	@scroll.window="scrolled = window.scrollY > 50"
	class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
	:class="scrolled ? 'py-3 bg-[#fbfaf7]/95 shadow-sm backdrop-blur' : 'py-5 bg-transparent'"
>
	<div class="container mx-auto flex justify-between items-center">
		<a href={`${base}/`} id="logo" class="text-xl md:text-2xl font-semibold tracking-normal">
			{title}
		</a>

		<div class="hidden md:flex space-x-8">
			{
				menuItems.map((item) => (
					<a
						href={item.link}
						class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[1px] after:bg-[#7b1e25] after:w-0 hover:after:w-full transition-all"
					>
						{item.name}
					</a>
				))
			}
		</div>

		<button
			@click="isOpen = !isOpen"
			class="md:hidden grid h-10 w-10 place-items-center border border-[#d8d0c0] text-[#241f1c] focus:outline-none"
			aria-label="Open navigation"
		>
			<span x-show="!isOpen"><Menu size={20} /></span>
			<span x-show="isOpen"><X size={20} /></span>
		</button>
	</div>

	<div x-show="isOpen" class="md:hidden absolute top-full left-0 w-full bg-[#fbfaf7] shadow-md">
		<div class="flex flex-col py-4 px-6 space-y-4">
			{
				menuItems.map((item) => (
					<a href={item.link} class="text-lg" @click="isOpen = false">
						{item.name}
					</a>
				))
			}
		</div>
	</div>
</nav>
