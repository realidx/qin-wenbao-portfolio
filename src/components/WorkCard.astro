---
import { Image } from 'astro:assets';
import type { Work } from '../data/galleryData';

interface Props {
	work: Work;
}

const { work } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<a href={`${base}/works/${work.id}`} class="group block">
	<div class="aspect-[4/5] overflow-hidden bg-[#ede6d8]">
		<Image
			src={work.coverImage}
			alt={work.title}
			quality={90}
			format="webp"
			width={work.coverImage.width}
			height={work.coverImage.height}
			class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
		/>
	</div>
	<div class="border-b border-[#d8d0c0] py-5">
		<div class="mb-3 flex items-center justify-between gap-4 text-xs uppercase tracking-[0.18em] text-[#7b1e25]">
			<span>{work.category}</span>
			<span>{work.year}</span>
		</div>
		<h2 class="text-2xl font-semibold text-[#241f1c]">{work.title}</h2>
		<p class="mt-2 text-sm text-[#6d6258]">{work.role}</p>
		<p class="mt-4 line-clamp-3 text-sm leading-7 text-[#514940]">{work.description}</p>
	</div>
</a>
