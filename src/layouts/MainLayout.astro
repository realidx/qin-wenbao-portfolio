---
import '../styles/global.css';
import siteConfig from '../../site.config.mjs';
import Footer from '../components/Footer.astro';
import NavBar from '../components/NavBar.astro';

const owner = siteConfig.owner;
const favicon = siteConfig.favicon;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en" class="h-full">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/x-icon" href={`${base}/${favicon}`} />

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Stage design and theatre costume portfolio" />
		<title>{owner} | Stage Design and Theatre Costume Portfolio</title>
	</head>
	<body>
		<NavBar />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
