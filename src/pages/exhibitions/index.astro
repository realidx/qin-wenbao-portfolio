---
import ExhibitionCard from '../../components/ExhibitionCard.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import { getExhibitions } from '../../data/imageStore';

const exhibitions = await getExhibitions();
---

<MainLayout>
	<section class="pt-32 pb-20 md:pb-28">
		<div class="container-custom">
			<div class="mb-14 max-w-3xl">
				<p class="mb-4 text-sm uppercase tracking-[0.22em] text-[#7b1e25]">Exhibitions</p>
				<h1 class="text-4xl md:text-6xl font-semibold text-[#241f1c]">Exhibitions</h1>
				<p class="mt-6 text-base leading-8 text-[#5d554c]">
					International exhibitions, pavilion records, curatorial participation, and presentation
					materials connected to stage design, costume research, and theatre education.
				</p>
			</div>

			<div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
				{exhibitions.map((exhibition) => <ExhibitionCard exhibition={exhibition} />)}
			</div>
		</div>
	</section>
</MainLayout>
