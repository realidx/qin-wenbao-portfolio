---
import MainLayout from '../layouts/MainLayout.astro';
import { Content as AboutPage } from '../content/about.md';
import siteConfig from '../../site.config.mjs';

const profileImage = siteConfig.profileImage;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<MainLayout>
	<section class="pt-32 pb-20">
		<div class="container-custom">
			<div class="max-w-2xl mb-16">
				<p class="mb-4 text-sm uppercase tracking-[0.22em] text-[#7b1e25]">Artist</p>
				<h1 class="text-4xl md:text-6xl font-semibold text-[#241f1c]">About the Artist</h1>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<img
						src=`${base}/images/${profileImage}`
						alt="Artist portrait"
						class="w-full h-auto border border-[#d8d0c0] bg-white p-3"
						width="720"
						height="720"
					/>
				</div>

				<div class="prose prose-neutral max-w-none text-[#4c453e] mb-6 prose-headings:text-[#241f1c] prose-a:text-[#7b1e25]">
					<AboutPage />
				</div>
			</div>
		</div>
	</section>
</MainLayout>
