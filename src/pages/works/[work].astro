---
import MainLayout from '../../layouts/MainLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import { getWork, getWorks } from '../../data/imageStore';

export const getStaticPaths = async () => {
	const works = await getWorks();
	return works.map((work) => ({
		params: { work: work.id },
	}));
};

const { work: workId } = Astro.params;
const work = await getWork(workId);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

if (!work) {
	throw new Error(`Work not found: ${workId}`);
}
---

<MainLayout>
	<section class="pt-32 pb-16">
		<div class="container-custom">
			<a href={`${base}/works`} class="text-sm text-[#7b1e25] hover:underline">
				Back to Works
			</a>

			<div class="mt-10 grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
				<div>
					<p class="mb-4 text-sm uppercase tracking-[0.22em] text-[#7b1e25]">{work.subtitle}</p>
					<h1 class="text-4xl md:text-6xl font-semibold leading-tight text-[#241f1c]">
						{work.title}
					</h1>
					<p class="mt-8 max-w-3xl text-lg leading-9 text-[#4c453e]">{work.description}</p>
				</div>

				<dl class="border-y border-[#d8d0c0] py-6 text-sm">
					<div class="flex justify-between gap-8 border-b border-[#e8dfd0] py-3">
						<dt class="text-[#8a7b6d]">Year</dt>
						<dd class="text-right text-[#241f1c]">{work.year}</dd>
					</div>
					<div class="flex justify-between gap-8 border-b border-[#e8dfd0] py-3">
						<dt class="text-[#8a7b6d]">Genre</dt>
						<dd class="text-right text-[#241f1c]">{work.category}</dd>
					</div>
					<div class="flex justify-between gap-8 border-b border-[#e8dfd0] py-3">
						<dt class="text-[#8a7b6d]">Type</dt>
						<dd class="text-right text-[#241f1c]">{work.type}</dd>
					</div>
					<div class="flex justify-between gap-8 py-3">
						<dt class="text-[#8a7b6d]">Role / Focus</dt>
						<dd class="text-right text-[#241f1c]">{work.role}</dd>
					</div>
				</dl>
			</div>
		</div>
	</section>

	<section class="pb-24 md:pb-32">
		<div class="container-custom">
			<PhotoGrid images={work.galleryImages} />
		</div>
	</section>
</MainLayout>
